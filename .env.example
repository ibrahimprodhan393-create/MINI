# Render will provide PORT automatically.
APP_NAME=Telegram Mini Shop
PUBLIC_APP_URL=https://your-render-service.onrender.com

# Neon pooled connection string is recommended for Render.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require

# Telegram bot credentials.
BOT_TOKEN=123456:ABCDEF_your_bot_token
BOT_USERNAME=your_bot_username
MINI_APP_SHORT_NAME=app
TELEGRAM_WEBHOOK_SECRET=
AUTO_PAYMENT_WEBHOOK_SECRET=

# Comma-separated Telegram numeric user IDs.
ADMIN_TELEGRAM_IDS=123456789

# Safe for first deploy. The app runs db/schema.sql at startup.
AUTO_MIGRATE=true

# Set false in production after testing.
DEBUG=false
DEV_TELEGRAM_USER_ID=100000001

REFERRAL_BONUS=10
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
